# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=raw_tweets
KAFKA_PRODUCER_TIMEOUT_MS=10000
CSV_PATH=./data/sample/tweets_sample.csv
MESSAGE_DELAY_SECONDS=1.0

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_APP_NAME=AutoRespondStreaming
SPARK_BATCH_INTERVAL_SECONDS=10
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoint
PYSPARK_SUBMIT_ARGS=--packages org.apache.spark:spark-sql-kafka-0-10_2.12:3.4.1 pyspark-shell

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=autorespond
DB_TIMEOUT_SECONDS=30
DB_CONNECT_RETRIES=5
DB_CONNECT_DELAY_SECONDS=3

# Model Configuration
MODEL_PATH=./model/trained_model.pkl
MODEL_CONFIDENCE_THRESHOLD=0.8

# Bloom Filter Configuration
BLOOM_FILTER_SIZE=100000
BLOOM_FILTER_NUM_HASHES=3

# LSH Configuration
LSH_NUM_ROWS=5
LSH_NUM_BANDS=10

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
DEBUG=false
